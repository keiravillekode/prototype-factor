  "key_features": [
    {
      "title": "Concatenative",
      "content": "Programs are sequences of words that transform the data stack. Composition is just concatenation.",
      "icon": "functional"
    },
    {
      "title": "Fully Compiled",
      "content": "Despite being dynamic and interactive, all code is compiled to native machine code.",
      "icon": "fast"
    },
    {
      "title": "Rich Standard Library",
      "content": "Ships with vocabularies for HTTP, databases, JSON, XML, regex, concurrency, UI, and more.",
      "icon": "powerful"
    },
    {
      "title": "Interactive Development",
      "content": "A bundled listener and IDE let you explore, test, and modify code live.",
      "icon": "interactive"
    },
    {
      "title": "Extensible Syntax",
      "content": "Parsing words let you extend the language's syntax from within Factor itself.",
      "icon": "extensible"
    },
    {
      "title": "Cross-platform",
      "content": "Runs on Linux, macOS, and Windows with a self-contained distribution.",
      "icon": "cross-platform"
    }
  ],
